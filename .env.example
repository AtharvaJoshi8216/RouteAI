# Route AI — copy this to .env and fill in your values
# At least ONE provider key is required

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Your Route AI API key — change this before deploying
ROUTE_AI_API_KEYS=your-secret-key-here

# Server
PORT=3000

# Environment
NODE_ENV=production

# Rate limit per API key per minute
RATE_LIMIT_PER_MIN=60
